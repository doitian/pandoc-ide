#!/bin/sh

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
PANDOC_DATA="${XDG_DATA_HOME:-$HOME/.local/share}/pandoc"

if [ -d "$PANDOC_DATA" ]; then
    REAL_PANDOC=$(
        PATH=$(printf '%s' "$PATH" | tr ':' '\n' | grep -vxF "$SCRIPT_DIR" | tr '\n' ':')
        command -v pandoc 2>/dev/null
    )
    if [ -n "$REAL_PANDOC" ]; then
        exec "$REAL_PANDOC" "$@"
    fi
fi

docker run --rm \
    --volume "$(pwd):/data" \
    --user "$(id -u):$(id -g)" \
    ghcr.io/doitian/pandoc-ide "$@"
